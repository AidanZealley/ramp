{
  "name": "ramp-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.10.5+sha512.9c161f433d85551c58f1b3a10b18cc3df72b5a02d2caee6566cc05b6f20addef947e795d90c39033bf92de55177ead69d87f62a9daadc91e7a2e3b58f49353a0",
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r pnpm:dev:web pnpm:dev:convex",
    "dev:web": "pnpm --filter @ramp/web dev",
    "dev:ts": "pnpm --filter @ramp/web dev:ts",
    "dev:convex": "npx convex dev",
    "build": "pnpm --filter @ramp/ride-engine build && pnpm --filter @ramp/trainer-io build && pnpm --filter @ramp/web build",
    "preview": "pnpm --filter @ramp/web preview",
    "test": "pnpm -r test",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.4.0",
    "@types/node": "^22.19.15",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "convex": "^1.36.0"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "1.168.17",
      "@tanstack/router-core": "1.168.17"
    }
  }
}
